{
  "name": "frontend",
  "private": true,
  "version": "5.63.2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:check": "lsof -i :3000 -i :3001 || echo 'No servers running'",
    "dev:restart": "npm run dev:stop && npm run dev",
    "dev:stop": "kill $(lsof -t -i:3000) 2>/dev/null || true",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "type-check": "tsc -b --noEmit",
    "lint:all": "npm run type-check && npm run lint",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@googlemaps/js-api-loader": "^2.0.2",
    "@hello-pangea/dnd": "^18.0.1",
    "@mantine/charts": "^8.2.7",
    "@mantine/core": "^8.2.7",
    "@mantine/dates": "^8.2.7",
    "@mantine/form": "^8.2.7",
    "@mantine/hooks": "^8.2.7",
    "@mantine/modals": "^8.2.7",
    "@mantine/notifications": "^8.2.7",
    "@tabler/icons-react": "^3.34.1",
    "@tanstack/react-query": "^5.85.5",
    "@vis.gl/react-google-maps": "^1.8.3",
    "axios": "^1.11.0",
    "canvas-confetti": "^1.9.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.17",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-plaid-link": "^4.1.1",
    "react-router-dom": "^7.8.2",
    "react-swipeable": "^7.0.2",
    "recharts": "^3.1.2",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tanstack/react-query-devtools": "^5.85.5",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.5.2",
    "@types/canvas-confetti": "^1.9.0",
    "@types/react": "^19.1.10",
    "@types/react-dom": "^19.1.7",
    "@vitejs/plugin-react": "^5.0.0",
    "@vitest/ui": "3.2.4",
    "eslint": "^9.33.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.20",
    "globals": "^16.3.0",
    "jsdom": "25.0.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.39.1",
    "vite": "^7.1.2",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "3.2.4"
  }
}
